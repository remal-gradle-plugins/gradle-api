{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>remal/renovate-config:global',
  ],
  'git-submodules': {
    enabled: false,
  },
  packageRules: [
    {
      matchCategories: [
        'java',
      ],
      allowedVersions: '(0,5.9999)',
      matchPackageNames: [
        '/^org\\.junit:/',
      ],
    },
  ],
}
