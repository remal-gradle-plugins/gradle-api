{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["github>remal/renovate-config:global"],

  "git-submodules": {
    // This is in beta for now, so let's use Dependabot to update Git submodules
    enabled: false
  },

  // $$$sync-with-template-modifiable: local $$$

  packageRules: [
    {
      matchCategories: ["java"],
      matchPackageNames: [
        "/^org\\.junit:/"
      ],
      allowedVersions: "(0,5.9999)",
    },
  ],

  // $$$sync-with-template-modifiable-end$$$
}
